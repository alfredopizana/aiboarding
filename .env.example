# ── LLM ──────────────────────────────────────────────────────────────
# Provider: openai | fake (fake = deterministic offline mode, no API calls)
AIBOARDING_LLM_PROVIDER=openai
AIBOARDING_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-...

# Embeddings: openai | hashing (hashing = deterministic offline embeddings)
AIBOARDING_EMBEDDINGS_PROVIDER=openai

# ── Storage ──────────────────────────────────────────────────────────
AIBOARDING_DATA_DIR=./data
AIBOARDING_VECTORSTORE_DIR=./data/vectorstore
AIBOARDING_AUDIT_DIR=./data/audit

# ── Persistence (users, plans, progress) ─────────────────────────────
AIBOARDING_PROGRESS_BACKEND=sqlite      # sqlite | firebase (future)
AIBOARDING_DB_PATH=./data/aiboarding.db
# Set DATABASE_URL to move BOTH relational data and embeddings to Postgres
# (pgvector) — app becomes stateless. Needs: pip install ".[postgres]".
# Railway injects this automatically when you add Postgres.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Tracing / LangSmith ──────────────────────────────────────────────
AIBOARDING_LANGSMITH_TRACING=false
AIBOARDING_LANGSMITH_API_KEY=
AIBOARDING_LANGSMITH_PROJECT=aiboarding

# ── UI ───────────────────────────────────────────────────────────────
AIBOARDING_SHOW_AUDIT_BUTTON=true       # "Ver auditoría" button under chat answers
AIBOARDING_UI_PASSWORD=                 # if set, the Streamlit app requires this password (hosted use)

# ── Ingestion (hosted entrypoint) ────────────────────────────────────
# On deploy, also ingest the bundled offline sample_docs (true/false). Off by
# default → only the real connectors (Confluence + GitHub) populate the KB.
AIBOARDING_INGEST_SAMPLE_DOCS=false

# ── Connectors (Phase 1) ─────────────────────────────────────────────
# Confluence
CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net/wiki
CONFLUENCE_EMAIL=you@company.com
CONFLUENCE_API_TOKEN=

# GitHub
GITHUB_TOKEN=
GITHUB_REPOS=org/repo1,org/repo2

# Google Drive (path to OAuth credentials / service account JSON)
GDRIVE_CREDENTIALS_PATH=./credentials.json
GDRIVE_FOLDER_IDS=

# ── Integrations (Phase 2) ───────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=onboarding-bot@company.com
